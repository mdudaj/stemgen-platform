{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stemgen-platform.local/schemas/evaluation/rubric_response.schema.json",
  "title": "Rubric Response",
  "description": "Structured expert rubric scores and comments for a generated artifact set.",
  "type": "object",
  "required": ["response_id", "invitation_id", "evaluator_id", "artifact_set_id", "submitted_at", "scores"],
  "properties": {
    "response_id": { "type": "string", "minLength": 1 },
    "invitation_id": { "type": "string", "minLength": 1 },
    "evaluator_id": { "type": "string", "minLength": 1 },
    "artifact_set_id": { "type": "string", "minLength": 1 },
    "submitted_at": { "type": "string", "format": "date-time" },
    "scores": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["criterion_id", "score"],
        "properties": {
          "criterion_id": { "type": "string", "minLength": 1 },
          "score": { "type": "integer", "minimum": 1, "maximum": 5 },
          "comment": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "overall_comment": { "type": "string" }
  },
  "additionalProperties": false
}
