{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stemgen-platform.local/schemas/workflows/research_workflow_definition.schema.json",
  "title": "Research Workflow Definition",
  "description": "Repo-owned configurable workflow definition compiled into an execution manifest.",
  "type": "object",
  "required": ["id", "name", "version", "description", "roles", "states", "transitions", "artifacts", "audit"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_\\-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "roles": { "type": "object", "additionalProperties": { "type": "object" } },
    "states": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "from", "to", "actor"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "actor": { "type": "string", "minLength": 1 },
          "async": { "type": "boolean" },
          "optional": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "artifacts": { "type": "array", "items": { "type": "string" } },
    "audit": {
      "type": "object",
      "required": ["require_run_id", "require_actor", "require_timestamp"],
      "properties": {
        "require_run_id": { "type": "boolean", "const": true },
        "require_actor": { "type": "boolean", "const": true },
        "require_timestamp": { "type": "boolean", "const": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
