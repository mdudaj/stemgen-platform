{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stemgen-platform.local/schemas/evaluation/rubric.schema.json",
  "title": "Expert Review Rubric",
  "description": "Feasibility evaluation rubric for generated STEM animation and narration artifacts.",
  "type": "object",
  "required": ["rubric_id", "version", "criteria"],
  "properties": {
    "rubric_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["criterion_id", "name", "definition", "scale_min", "scale_max", "comment_required"],
        "properties": {
          "criterion_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "definition": { "type": "string", "minLength": 1 },
          "scale_min": { "type": "integer", "const": 1 },
          "scale_max": { "type": "integer", "const": 5 },
          "comment_required": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
