{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stemgen-platform.local/schemas/curriculum/topic_selection_decisions.schema.json",
  "title": "Topic Selection Decisions",
  "description": "Human topic selection decisions required before candidate topics are promoted.",
  "type": "object",
  "required": ["selection_run_id", "source_snapshot_id", "decisions"],
  "properties": {
    "selection_run_id": { "type": "string", "minLength": 1 },
    "source_snapshot_id": { "type": "string", "format": "uuid" },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["topic_id", "decision", "reviewer", "reviewed_at", "reason", "source_references_checked", "automated_review_considered", "notes"],
        "properties": {
          "topic_id": { "type": "string", "minLength": 1 },
          "decision": { "type": "string", "enum": ["accepted", "rejected", "needs_revision"] },
          "reviewer": { "type": "string", "minLength": 1 },
          "reviewed_at": { "type": "string", "format": "date-time" },
          "reason": { "type": "string", "minLength": 1 },
          "source_references_checked": { "type": "boolean" },
          "automated_review_considered": { "type": "boolean" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
