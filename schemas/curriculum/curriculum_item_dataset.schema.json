{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stemgen-platform.local/schemas/curriculum/curriculum_item_dataset.schema.json",
  "title": "Curriculum Item Dataset",
  "description": "A deterministic dataset of normalized curriculum items extracted from official curriculum sources.",
  "type": "object",
  "required": ["dataset_id", "source_snapshot_id", "created_at", "extractor_version", "items"],
  "properties": {
    "dataset_id": { "type": "string", "minLength": 1 },
    "source_snapshot_id": { "type": "string", "format": "uuid" },
    "created_at": { "type": "string", "format": "date-time" },
    "extractor_version": { "type": "string", "minLength": 1 },
    "items": {
      "type": "array",
      "items": { "type": "object" },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
