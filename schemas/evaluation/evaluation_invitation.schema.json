{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stemgen-platform.local/schemas/evaluation/evaluation_invitation.schema.json",
  "title": "Evaluation Invitation",
  "description": "Invitation record linking an evaluator to a secure web review session.",
  "type": "object",
  "required": ["invitation_id", "evaluator_id", "artifact_set_id", "review_url_token", "status", "expires_at"],
  "properties": {
    "invitation_id": { "type": "string", "minLength": 1 },
    "evaluator_id": { "type": "string", "minLength": 1 },
    "artifact_set_id": { "type": "string", "minLength": 1 },
    "review_url_token": { "type": "string", "minLength": 8 },
    "status": { "type": "string", "enum": ["draft", "sent", "opened", "submitted", "expired", "cancelled"] },
    "preferred_channel": { "type": "string", "enum": ["web", "email", "whatsapp"] },
    "expires_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
