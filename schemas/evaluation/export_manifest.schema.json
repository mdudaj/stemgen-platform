{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stemgen-platform.local/schemas/evaluation/export_manifest.schema.json",
  "title": "Export Manifest",
  "description": "Manifest for analysis-ready evidence exports and artifact bundles.",
  "type": "object",
  "required": ["export_batch_id", "created_at", "formats", "files", "privacy_reviewed"],
  "properties": {
    "export_batch_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "formats": { "type": "array", "items": { "type": "string", "enum": ["csv", "json", "zip", "markdown", "pdf"] } },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256", "format"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
          "format": { "type": "string", "enum": ["csv", "json", "zip", "markdown", "pdf"] }
        },
        "additionalProperties": false
      }
    },
    "privacy_reviewed": { "type": "boolean" },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
